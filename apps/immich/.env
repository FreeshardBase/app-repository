# You can find documentation for all the supported env variables at https://immich.app/docs/install/environment-variables

# The location where your uploaded files are stored
UPLOAD_LOCATION=./library

# The Immich version to use. You can pin this to a specific version like "v1.71.0"
IMMICH_VERSION=v2.7.5

# Connection secrets for postgres and typesense. You should change these to random passwords
# TYPESENSE_API_KEY=some-random-text
DB_PASSWORD=postgres

# The values below this line do not need to be changed
###################################################################################
DB_HOSTNAME=immich_postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Force the VectorChord extension. The combined postgres image ships both
# pgvecto.rs (legacy, deprecated, crashing) and VectorChord. Setting this
# triggers immich's in-place conversion of existing embeddings from pgvecto.rs
# to VectorChord on startup (non-destructive: pgvecto.rs is read, not dropped).
DB_VECTOR_EXTENSION=vectorchord

REDIS_HOSTNAME=immich_redis
