networks:
    portal:
        external: true

services:
    syncthing:
        restart: always
        image: syncthing/syncthing:2.0.16
        container_name: syncthing
        hostname: syncthing
        user: "0:0"
        volumes:
        - "{{ fs.app_data }}/config:/var/syncthing/config"
        - "{{ fs.shared }}:/var/syncthing/Sync"
        environment:
        - STGUIADDRESS=http://0.0.0.0:8384
        networks:
        - portal
